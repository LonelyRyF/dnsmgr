APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = {dbhost}
DATABASE = {dbname}
USERNAME = {dbuser}
PASSWORD = {dbpwd}
HOSTPORT = {dbport}
CHARSET = utf8mb4
PREFIX = {dbprefix}
DEBUG = false

[LANG]
default_lang = zh-cn

[JWT]
# JWT 密钥（安装时自动生成随机值，无需手动修改）
JWT_SECRET = your-secret-key-here-change-in-production
# JWT 签发者标识
JWT_ISSUER = dnsmgr
# Access Token 有效期（秒，默认 2 小时）
JWT_TTL = 7200
# Refresh Token 有效期（秒，默认 7 天）
JWT_REFRESH_TTL = 604800