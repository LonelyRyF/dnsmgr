APP_DEBUG = false

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = {dbhost}
DATABASE = {dbname}
USERNAME = {dbuser}
PASSWORD = {dbpwd}
HOSTPORT = {dbport}
CHARSET = utf8mb4
PREFIX = {dbprefix}
DEBUG = false

[LANG]
default_lang = zh-cn

[JWT]
JWT_SECRET = your-secret-key-here-change-in-production
JWT_ISSUER = dnsmgr
JWT_TTL = 7200
JWT_REFRESH_TTL = 604800